rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to get user role
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isAdmin() {
      return request.auth != null && getUserRole() == 'admin';
    }
    
    function isTeacher() {
      return request.auth != null && getUserRole() == 'teacher';
    }
    
    function isSecretary() {
      return request.auth != null && getUserRole() == 'secretary';
    }
    
    function isProprietor() {
      return request.auth != null && getUserRole() == 'proprietor';
    }
    
    function isParent() {
      return request.auth != null && getUserRole() == 'parent';
    }
    
    function isStudent() {
      return request.auth != null && getUserRole() == 'student';
    }

    // Users collection - users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin() || isTeacher() || isSecretary() || isProprietor();
    }

    // Students collection
    match /students/{studentId} {
      allow read, write: if isAdmin() || isSecretary();
      allow read, write: if isTeacher();
      allow read: if isParent() && resource.data.parentId == request.auth.uid;
      allow read: if isStudent() && resource.data.userId == request.auth.uid;
    }

    // Parents collection
    match /parents/{parentId} {
      allow read, write: if isAdmin() || isSecretary();
      allow read, write: if request.auth != null && request.auth.uid == parentId;
    }

    // Teachers collection
    match /teachers/{teacherId} {
      allow read, write: if isAdmin() || isProprietor();
      allow read, write: if request.auth != null && request.auth.uid == teacherId;
    }

    // Classes collection
    match /classes/{classId} {
      allow read, write: if isAdmin();
      allow read, write: if isTeacher();
      allow read: if isStudent() || isParent();
    }

    // Subjects collection
    match /subjects/{subjectId} {
      allow read, write: if isAdmin();
      allow read, write: if isTeacher();
      allow read: if isStudent() || isParent();
    }

    // Fee structures collection
    match /feeStructures/{feeId} {
      allow read, write: if isAdmin() || isSecretary();
      allow read: if isParent() || isStudent();
    }

    // Payments collection
    match /payments/{paymentId} {
      // Validate payment payload on create/update
      function isPaymentDataValid() {
        let data = request.resource.data;
        return data.studentId is string
          && data.amount is number && data.amount > 0
          && data.paymentMethod in ['cash','bank_transfer','online']
          && data.status in ['completed','incomplete']
          && data.receiptNumber is string && data.receiptNumber.size() > 0
          && (!('transactionId' in data) || data.transactionId is string)
          && (!('feeStructureId' in data) || data.feeStructureId is string)
          && (!('paymentDate' in data) || data.paymentDate is timestamp)
          && (!('recordedBy' in data) || data.recordedBy == request.auth.uid);
      }
      function isUpdateImmutableFieldsUnchanged() {
        return request.resource.data.studentId == resource.data.studentId
          && request.resource.data.feeStructureId == resource.data.feeStructureId
          && request.resource.data.receiptNumber == resource.data.receiptNumber;
      }
      function isStudentOwner() {
        return isStudent() && get(/databases/$(database)/documents/students/$(resource.data.studentId)).data.userId == request.auth.uid;
      }
      function isParentOfStudent() {
        return isParent() && (resource.data.studentId in get(/databases/$(database)/documents/parents/$(request.auth.uid)).data.children);
      }

      allow create: if (isAdmin() || isSecretary()) && isPaymentDataValid();
      allow update: if (isAdmin() || isSecretary()) && isPaymentDataValid() && isUpdateImmutableFieldsUnchanged();
      allow delete: if isAdmin() || isSecretary();

      allow read: if isAdmin() || isSecretary() || isParentOfStudent() || isStudentOwner();
    }

    // Attendance collection
    match /attendance/{attendanceId} {
      allow read, write: if isAdmin() || isTeacher();
      allow read: if isParent() && resource.data.studentId in get(/databases/$(database)/documents/parents/$(request.auth.uid)).data.children;
      allow read: if isStudent() && resource.data.studentId == request.auth.uid;
    }

    // Results collection
    match /results/{resultId} {
      allow read, write: if isAdmin() || isTeacher();
      allow read: if isParent() && resource.data.studentId in get(/databases/$(database)/documents/parents/$(request.auth.uid)).data.children;
      allow read: if isStudent() && resource.data.studentId == request.auth.uid;
    }

    // Assignments collection
    match /assignments/{assignmentId} {
      allow read, write: if isAdmin() || isTeacher();
      allow read: if isStudent();
    }

    // Assignment submissions collection
    match /assignmentSubmissions/{submissionId} {
      allow read, write: if isAdmin() || isTeacher();
      allow read, write: if isStudent() && resource.data.studentId == request.auth.uid;
    }

    // Academic sessions collection
    match /academicSessions/{sessionId} {
      allow read, write: if isAdmin() || isSecretary();
      allow read: if isTeacher() || isStudent() || isParent();
    }

    // Events collection
    match /events/{eventId} {
      allow read, write: if isAdmin() || isSecretary();
      allow read: if isTeacher() || isStudent() || isParent();
    }

    // Notifications collection
    match /notifications/{notificationId} {
      allow read, write: if isAdmin();
      allow read, write: if request.auth != null && resource.data.recipientId == request.auth.uid;
    }

    // Default rule - deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}